{
  "extends": "@gitinspect/config/tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "jsx": "react-jsx",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],
    "paths": {
      "@gitinspect/pi/*": ["./src/*"],
      "@gitinspect/db/*": ["../db/src/*"],
      "@gitinspect/ui/*": ["../ui/src/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["node_modules"]
}
